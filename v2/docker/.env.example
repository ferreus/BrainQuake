# Copy to .env (same directory) and point this at your real FreeSurfer license.txt
# (free registration: https://surfer.nmr.mgh.harvard.edu/registration.html).
# Never commit an actual license.txt or a filled-in .env.
FS_LICENSE_HOST=/absolute/path/to/your/license.txt

# Base image the api/worker Dockerfile builds FROM -- built separately via
# build-base.sh (see base.Dockerfile). Only needs setting if you're pinning a
# specific FS/FSL version tag instead of the default "brainquake-base:latest".
# BASE_IMAGE=brainquake-base:fs7.4.1-fsl-flirt

# Where the web container's browser bundle should reach the api service.
# Defaults to http://localhost:8000, which works when you're browsing from
# the same machine docker compose runs on (the published host port). Change
# this if the server is reachable at a different host/port from the browser.
# WEB_API_BASE_URL=http://localhost:8000
